# Copy to .env and edit. The backend reads these at startup.

# Stream sources: comma-separated cam_id=uri pairs.
# RTSP, local files, or "0" for the default webcam are all valid.
LABOR_INTEL_STREAM_SOURCES=cam_01=rtsp://localhost:8554/cam_01,cam_02=rtsp://localhost:8554/cam_02

# Inference
LABOR_INTEL_WEIGHTS_PATH=training/artifacts/weights/best.onnx
LABOR_INTEL_INFERENCE_PROVIDER=auto    # auto | cuda | cpu
LABOR_INTEL_DETECTION_CONF_THRESHOLD=0.35

# Stream sampling
LABOR_INTEL_STREAM_TARGET_FPS=3

# Analytics tick
LABOR_INTEL_ANALYTICS_TICK_SECONDS=3

# Storage
LABOR_INTEL_SQLITE_PATH=data/labor_intel.db
LABOR_INTEL_SQLITE_RETENTION_HOURS=24

# API
LABOR_INTEL_API_HOST=0.0.0.0
LABOR_INTEL_API_PORT=8000

# Logging
LABOR_INTEL_LOG_LEVEL=INFO
